# Copy to .env and fill in your keys

GEMINI_API_KEY=your-gemini-key-here
# Google Cloud Console → enable YouTube Data API v3 → Credentials → API key
# Must start with AIza... (NOT an AQ key from AI Studio)
YOUTUBE_API_KEY=your-youtube-key-here

# Optional — default tries gemini-3.5-flash, then fallbacks
# GEMINI_MODEL=gemini-3.5-flash

# Optional — store review links (set when app is on App Store / Play Store)
# VITE_PLAY_STORE_PACKAGE=com.yourcompany.fridgeai
# VITE_APP_STORE_ID=1234567890
# Or use full URLs instead:
# VITE_PLAY_STORE_REVIEW_URL=https://play.google.com/store/apps/details?id=com.yourcompany.fridgeai
# VITE_APP_STORE_REVIEW_URL=https://apps.apple.com/app/id1234567890?action=write-review

PORT=3002
# Local dev only — on Render, RENDER_EXTERNAL_URL is set automatically
APP_URL=http://localhost:5173
